<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/videoActionsSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="22dp">

    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/videoActionPosterImage"
            android:layout_width="70dp"
            android:layout_height="104dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/EmbyProShapeAppearanceSheetPoster" />

        <TextView
            android:id="@+id/videoActionTitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoActionReplayRow"
        style="@style/VideoActionRowStyle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_video_action_replay" />

        <TextView
            style="@style/VideoActionRowTextStyle"
            android:text="@string/action_replay_from_start" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoActionCastRow"
        style="@style/VideoActionRowStyle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_video_action_cast" />

        <TextView
            style="@style/VideoActionRowTextStyle"
            android:text="@string/action_cast" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoActionExternalRow"
        style="@style/VideoActionRowStyle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_video_action_external" />

        <TextView
            style="@style/VideoActionRowTextStyle"
            android:text="@string/action_external_player" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoActionSourceRow"
        style="@style/VideoActionRowStyle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_video_action_search" />

        <TextView
            style="@style/VideoActionRowTextStyle"
            android:text="@string/action_search_other_source" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_video_action_pro_badge"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:text="@string/pro_badge"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoActionDeleteRow"
        style="@style/VideoActionRowStyle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_video_action_delete" />

        <TextView
            style="@style/VideoActionRowTextStyle"
            android:text="@string/action_delete_video" />
    </LinearLayout>

</LinearLayout>
