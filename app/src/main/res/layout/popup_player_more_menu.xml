<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable glass popup card:
  use the Library-style outer shell (`bg_home_poster_glass_card`) and the same
  rounded option rows for future lightweight selection popups.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="224dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_poster_glass_card"
    android:elevation="12dp"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:text="@string/more_actions"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <include
        android:id="@+id/playerMenuContinuousOption"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp" />

    <include
        android:id="@+id/playerMenuRotateOption"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <include
        android:id="@+id/playerMenuPipOption"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="2dp"
        android:background="@color/card_stroke" />

    <include
        android:id="@+id/playerMenuSpeed1Option"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <include
        android:id="@+id/playerMenuSpeed125Option"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <include
        android:id="@+id/playerMenuSpeed15Option"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <include
        android:id="@+id/playerMenuSpeed2Option"
        layout="@layout/item_player_more_option"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

</LinearLayout>
