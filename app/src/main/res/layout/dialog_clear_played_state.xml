<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_dialog"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp">

    <TextView
        android:id="@+id/clearPlayedStateDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/clear_played_state_confirm_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/clearPlayedStateDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/clear_played_state_confirm_message"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/clearPlayedStateDialogCancelButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_glass_dialog_button_secondary"
            android:gravity="center"
            android:minWidth="88dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@android:string/cancel"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/clearPlayedStateDialogConfirmButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_glass_dialog_button_primary"
            android:gravity="center"
            android:minWidth="112dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/clear_played_state"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
