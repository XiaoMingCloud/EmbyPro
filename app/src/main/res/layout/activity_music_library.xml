<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/music_library_background">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-84dp"
        android:layout_marginTop="-68dp"
        android:background="@drawable/bg_music_library_glow_magenta" />

    <View
        android:layout_width="540dp"
        android:layout_height="540dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-72dp"
        android:background="@drawable/bg_music_library_glow_cyan" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_music_library_depth" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/musicLibraryScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="30dp"
        android:paddingTop="42dp"
        android:paddingEnd="30dp"
        android:paddingBottom="34dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_music_library_glass_card"
                android:elevation="14dp"
                android:minHeight="540dp"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="92dp"
                        android:layout_height="92dp"
                        android:background="@drawable/bg_music_library_cover_glow">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/music_library_cover"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_launcher_emby_source" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/musicLibraryTitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.01"
                            android:text="@string/music_library_name"
                            android:textColor="@color/music_library_title"
                            android:textSize="31sp" />

                        <LinearLayout
                            android:id="@+id/musicLibraryPartitionRow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/musicLibraryPartitionText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/music_library_route"
                                android:textColor="@color/music_library_meta"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="&#8226;"
                                android:textColor="@color/music_library_meta"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_music_library_song" />

                            <TextView
                                android:id="@+id/musicLibraryCountText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/music_library_count"
                                android:textColor="@color/music_library_meta"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/musicLibraryStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/music_library_meta"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="26dp"
                    android:layout_marginBottom="20dp"
                    android:alpha="0.88"
                    android:background="@drawable/bg_music_library_divider" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alignmentMode="alignMargins"
                    android:columnCount="3"
                    android:rowCount="2"
                    android:useDefaultMargins="false">

                    <LinearLayout
                        android:id="@+id/musicLibrarySongsEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginBottom="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_song" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_songs"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/musicLibrarySongsStatsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/musicLibraryFavoritesEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginBottom="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_favorite" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_favorites"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/music_list_favorites_subtitle"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/musicLibraryPlaylistsEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginBottom="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_download" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_playlists"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/musicLibraryPlaylistsStatsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/musicLibraryAlbumsEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_album" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_albums"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/musicLibraryAlbumsStatsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/musicLibraryArtistsEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_artist" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_artists_short"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/musicLibraryArtistsStatsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/musicLibraryFoldersEntry"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_music_library_folder" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/music_library_entry_folders"
                            android:textColor="@color/music_library_accent"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/music_list_folders_subtitle"
                            android:textColor="@color/music_library_meta"
                            android:textSize="12sp" />
                    </LinearLayout>
                </GridLayout>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:contentDescription="@string/music_library_expand"
                    android:src="@drawable/ic_music_library_chevron_down" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/musicLibraryLoadingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/loading"
            android:textColor="@color/music_library_meta"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/musicLibraryEmptyContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/music_settings_empty"
            android:textColor="@color/music_library_meta"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/musicLibraryErrorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/musicLibraryErrorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/music_library_meta"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/musicLibraryRetryButton"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:layout_marginTop="18dp"
            android:text="@string/retry"
            android:textAllCaps="false"
            android:textColor="@color/music_library_background"
            app:backgroundTint="@color/music_library_accent"
            app:cornerRadius="22dp"
            app:elevation="0dp" />
    </LinearLayout>

</FrameLayout>
