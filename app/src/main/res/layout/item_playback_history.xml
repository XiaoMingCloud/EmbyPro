<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="114dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="7dp"
    android:paddingEnd="16dp"
    android:paddingBottom="7dp">

    <FrameLayout
        android:layout_width="136dp"
        android:layout_height="82dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/playbackHistoryPosterImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/EmbyProShapeAppearanceGridPoster" />

        <View
            android:id="@+id/playbackHistoryProgressTrack"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_gravity="bottom"
            android:background="#14FF5A9D" />

        <View
            android:id="@+id/playbackHistoryProgressFill"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_gravity="bottom|start"
            android:background="#FFFF5A9D" />

        <TextView
            android:id="@+id/playbackHistoryDurationBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_playback_duration_badge"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/playbackHistoryTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/playbackHistoryLibraryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/playbackHistoryTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/playbackHistoryCheckBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:buttonTint="@color/nav_active"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/playbackHistoryFavoriteButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="6dp"
        android:src="@drawable/ic_favorite_heart_filled"
        android:tint="#FFE24D6E"
        android:visibility="gone" />

</LinearLayout>
