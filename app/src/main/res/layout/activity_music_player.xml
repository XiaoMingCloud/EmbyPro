<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_music_library_glass_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/musicPlayerBackButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:padding="8dp"
                android:src="@drawable/ic_back_ios_light" />

            <TextView
                android:id="@+id/musicPlayerQueueTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:textColor="@color/music_library_meta"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/musicPlayerSongTabButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_dialog_button_primary"
                android:gravity="center"
                android:minWidth="88dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/music_player_page_song"
                android:textColor="@color/music_library_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/musicPlayerLyricsTabButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_glass_dialog_button_secondary"
                android:gravity="center"
                android:minWidth="88dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/music_player_page_lyrics"
                android:textColor="@color/music_library_title"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingTop="10dp"
            android:paddingEnd="6dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:id="@+id/musicPlayerSongPage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_home_poster_glass_card"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/musicPlayerCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />

                        <ProgressBar
                            android:id="@+id/musicPlayerLoadingIndicator"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/music_library_accent"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/musicPlayerTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:textColor="@color/music_library_title"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/musicPlayerSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:textColor="@color/music_library_meta"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="4dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/musicPlayerFavoriteButton"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_music_player_favorite_button"
                            android:contentDescription="@string/favorite"
                            android:padding="11dp"
                            android:src="@drawable/ic_favorite_heart_outline" />

                        <ImageButton
                            android:id="@+id/musicPlayerCacheButton"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_music_player_favorite_button"
                            android:contentDescription="@string/music_player_cache"
                            android:padding="11dp"
                            android:src="@drawable/ic_music_library_download"
                            android:tint="@color/music_library_title" />

                        <ImageButton
                            android:id="@+id/musicPlayerDeleteButton"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_music_player_favorite_button"
                            android:contentDescription="@string/action_delete_music"
                            android:padding="11dp"
                            android:src="@drawable/ic_video_action_delete"
                            android:tint="@color/music_library_title" />

                        <ImageButton
                            android:id="@+id/musicPlayerLyricsButton"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="12dp"
                            android:visibility="gone"
                            android:background="@drawable/bg_music_player_favorite_button"
                            android:contentDescription="@string/music_player_lyrics"
                            android:padding="10dp"
                            android:src="@drawable/ic_music_lyrics"
                            android:tint="@color/music_library_title" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/musicPlayerLyricsPage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_home_poster_glass_card"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/music_player_lyrics"
                        android:textColor="@color/music_library_title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:id="@+id/musicPlayerLyricsScroll"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="14dp"
                        android:fillViewport="true"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/musicPlayerLyricsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical" />
                    </ScrollView>
                </LinearLayout>
            </FrameLayout>

            <SeekBar
                android:id="@+id/musicPlayerSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:progressTint="@color/music_library_accent"
                android:thumbTint="@color/music_library_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/musicPlayerElapsedText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textColor="@color/music_library_meta"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/musicPlayerDurationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/music_library_meta"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/musicPlayerPreviousButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/music_player_previous"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/musicPlayerPlayPauseButton"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_music_player_play_ring"
                    android:contentDescription="@string/play"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="@android:color/white" />

                <ImageButton
                    android:id="@+id/musicPlayerNextButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/music_player_next"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
