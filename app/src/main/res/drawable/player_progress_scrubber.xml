<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="18dp"
        android:height="18dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#D8161A20"
                android:startColor="#E6323740" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
            <size
                android:width="18dp"
                android:height="18dp" />
        </shape>
    </item>

    <item
        android:width="13dp"
        android:height="13dp"
        android:gravity="center"
        android:drawable="@mipmap/ic_launcher_round" />
</layer-list>
